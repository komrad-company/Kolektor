{
  "version": "0.8",
  "index_id": "ocsf-network",
  "doc_mapping": {
    "mode": "dynamic",
    "field_mappings": [
      {
        "name": "class_uid",
        "type": "u64",
        "coerce": true,
        "fast": true
      },
      {
        "name": "category_uid",
        "type": "u64",
        "coerce": true,
        "fast": true
      },
      {
        "name": "severity_id",
        "type": "u64",
        "coerce": true,
        "fast": true
      },
      {
        "name": "time",
        "type": "datetime",
        "fast": true,
        "fast_precision": "milliseconds",
        "input_formats": [
          "unix_timestamp"
        ],
        "output_format": "unix_timestamp_millis"
      },
      {
        "name": "tenant_id",
        "type": "text",
        "fast": true,
        "tokenizer": "raw"
      },
      {
        "name": "datasource_id",
        "type": "text",
        "fast": true,
        "tokenizer": "raw"
      },
      {
        "name": "raw",
        "type": "text",
        "stored": true,
        "indexed": false
      },
      {
        "name": "action",
        "type": "text",
        "fast": true,
        "tokenizer": "raw"
      },
      {
        "name": "action_id",
        "type": "u64",
        "coerce": true,
        "fast": true
      },
      {
        "name": "src_endpoint",
        "type": "json",
        "fast": true
      },
      {
        "name": "dst_endpoint",
        "type": "json",
        "fast": true
      },
      {
        "name": "connection_info",
        "type": "json"
      },
      {
        "name": "metadata",
        "type": "json"
      },
      {
        "name": "unmapped",
        "type": "json"
      }
    ],
    "timestamp_field": "time"
  },
  "search_settings": {
    "default_search_fields": [
      "tenant_id",
      "datasource_id"
    ]
  }
}